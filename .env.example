# --- Mode -------------------------------------------------------------------
# testnet  -> https://testnet.binancefuture.com (paper money, real prices)
# live     -> https://fapi.binance.com (real money — use with care)
MODE=testnet

# --- Binance Futures USDT-M -------------------------------------------------
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Telegram ---------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Comma-separated list of Telegram numeric user IDs that may control the bot.
TELEGRAM_ALLOWED_USER_IDS=

# --- AI (OpenRouter) --------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# --- Market data ------------------------------------------------------------
# Optional. Free CoinGecko tier works without a key.
COINGECKO_API_KEY=

# --- Storage / runtime ------------------------------------------------------
DB_PATH=./data/bot.db
LOG_LEVEL=INFO

# Local timezone for Telegram display and weekly AI schedule (IANA name).
TIMEZONE=Asia/Jakarta
